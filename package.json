{
  "name": "otls",
  "private": true,
  "version": "0.1.0",
  "description": "Online Teaching & Learning System — v0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:backend": "bun --cwd apps/backend run dev",
    "dev:frontend": "bun --cwd apps/frontend run dev",
    "build": "bun --filter '*' build",
    "lint": "biome check apps",
    "lint:fix": "biome check --write apps",
    "format": "biome format --write apps",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "deadcode": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "knip": "^6.6.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=20"
  }
}
