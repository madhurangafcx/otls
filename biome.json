{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["apps/**/*.{ts,tsx}", "packages/**/*.{ts,tsx}"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noArrayIndexKey": "off",
        "noImplicitAnyLet": "warn"
      },
      "style": {
        "noParameterAssign": "off",
        "useTemplate": "warn",
        "useConst": "error",
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "noUselessLoneBlockStatements": "warn"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off",
        "useButtonType": "off",
        "noSvgWithoutTitle": "off",
        "useAriaPropsSupportedByRole": "warn",
        "useValidAriaRole": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": ["apps/frontend/next-env.d.ts"],
      "linter": { "enabled": false }
    }
  ]
}
