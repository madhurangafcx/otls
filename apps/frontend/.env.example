# apps/frontend/.env.example
# Copy to apps/frontend/.env.local (Next.js reads .env.local; never commit).
# In production, these values live in Fly.io secrets on the frontend app:
#   flyctl secrets set KEY=value -a otls-frontend

# ── Supabase (browser-safe)
# These NEXT_PUBLIC_* vars are bundled into the client JavaScript — safe to expose.
# The anon key is designed for client use; RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Backend API
# Where the Bun+Hono backend runs. Local dev: localhost:8080. Prod: api subdomain.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Observability (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ── SERVER-ONLY (never prefixed with NEXT_PUBLIC_)
# These are read only in Server Components, Route Handlers, and Server Actions.
# Never bundled into client JS.
# SUPABASE_SERVICE_ROLE_KEY=  # ← DO NOT SET HERE. Frontend should NEVER have this. Backend only.
