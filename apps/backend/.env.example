# apps/backend/.env.example
# Copy to apps/backend/.env (never commit the real .env file).
# In production, these values live in Fly.io secrets: `flyctl secrets set KEY=value -a otls-backend`

# ── Runtime
NODE_ENV=development
PORT=8080

# ── Supabase (server-side)
# Project URL — safe to expose, but we keep it in env for config symmetry
SUPABASE_URL=https://your-project-ref.supabase.co

# anon key — used only for the public OAuth callback exchange on the backend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# service_role key — BYPASSES RLS. Backend-only. Never to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Only set if your Supabase project uses legacy HS256 JWT signing.
# Verify by hitting https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#   - If it returns a {"keys":[...]} JSON, you are on asymmetric/RS256 — leave this blank.
#   - If it 404s, you are on HS256 — paste the JWT Secret from Supabase API settings.
# SUPABASE_JWT_SECRET=

# ── CORS
FRONTEND_URL=http://localhost:3000

# ── JWT
JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
JWT_AUDIENCE=authenticated

# ── Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_UPLOAD_MAX=10

# ── Observability
LOG_LEVEL=info
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=development
